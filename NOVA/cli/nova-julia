async function cmdValidate(typeName, value) {
  const { TYPE_ISOMORPHISMS } = await import(protocolPath);
  
  if (!typeName || value === undefined) {
    console.error('Error: Type name and value required');
    console.error('Usage: nova-julia validate <type> <value>');
    process.exit(1);
  }
  
  const typeSpec = TYPE_ISOMORPHISMS[typeName];
  if (!typeSpec) {
    console.error(`Error: Unknown type '${typeName}'`);
    console.error('Run "nova-julia types" to see available types');
    process.exit(1);
  }
  
  const parsed = parseValue(value);
  
  // Basic validation
  let valid = true;
  const issues = [];
  
  if (typeName === 'Matrix{Float64}') {
    if (!Array.isArray(parsed)) {
      valid = false;
      issues.push('Value must be an array');
    } else if (parsed.length === 0) {
      valid = false;
      issues.push('Matrix cannot be empty');
    } else {
      const cols = parsed[0]?.length;
      for (let i = 0; i < parsed.length; i++) {
        if (!Array.isArray(parsed[i])) {
          valid = false;
          issues.push(`Row ${i} is not an array`);
        } else if (parsed[i].length !== cols) {
          valid = false;
          issues.push(`Row ${i} has inconsistent length`);
        }
      }
    }
  } else if (typeName.startsWith('Vector')) {
    if (!Array.isArray(parsed)) {
      valid = false;
      issues.push('Value must be an array');
    }
  } else if (typeName === 'Float64') {
    if (typeof parsed !== 'number') {
      valid = false;
      issues.push('Value must be a number');
    }
  }
  
  if (valid) {
    console.log(`✓ Valid ${typeName}`);
    console.log(`  JavaScript type: ${typeSpec.js}`);
    console.log(`  Motoko type: ${typeSpec.motoko}`);
  } else {
    console.log(`✗ Invalid ${typeName}`);
    for (const issue of issues) {
      console.log(`  • ${issue}`);
    }
    process.exit(1);
  }
}

