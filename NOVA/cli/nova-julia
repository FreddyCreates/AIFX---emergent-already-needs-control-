// ─── Main ─────────────────────────────────────────────────────────────────────

async function main() {
  const args = process.argv.slice(2);
  
  if (args.length === 0) {
    cmdHelp();
    return;
  }
  
  const parsed = parseArgs(args);
  
  switch (parsed.command) {
    case 'call':
      await cmdCall(parsed.function, parsed.options);
      break;
    case 'list':
      await cmdList();
      break;
    case 'types':
      await cmdTypes();
      break;
    case 'info':
      await cmdInfo(parsed.function);
      break;
    case 'validate':
      await cmdValidate(parsed.positional[0], parsed.positional[1]);
      break;
    case 'help':
    case '--help':
    case '-h':
      cmdHelp();
      break;
    case 'version':
    case '--version':
    case '-v':
      cmdVersion();
      break;
    default:
      console.error(`Unknown command: ${parsed.command}`);
      console.error('Run "nova-julia help" for usage');
      process.exit(1);
  }
}

main().catch(error => {
  console.error(`Fatal error: ${error.message}`);
  process.exit(1);
});
