#!/usr/bin/env node

/**
 * nova-julia — CLI for NOVA Julia-Motoko Bridge
 * 
 * Command-line interface for calling Julia computational functions
 * through the NOVA bridge.
 * 
 * Usage:
 *   nova-julia call <function> [options]
 *   nova-julia list
 *   nova-julia types
 *   nova-julia validate <type> <value>
 *   nova-julia info <function>
 * 
 * @module NOVA/cli/nova-julia
 * @version 1.0.0
 * @powered-by NOVA (Networked Omniscient Verified Architecture)
 */

import { readFileSync, writeFileSync, existsSync } from 'fs';
import { resolve, dirname } from 'path';
import { fileURLToPath } from 'url';

// ESM compatibility
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// ─── Import Bridge ────────────────────────────────────────────────────────────

// Dynamic import for the protocol
const protocolPath = resolve(__dirname, '../protocols/PROTOCOL-JULIA.js');

// ─── Constants ────────────────────────────────────────────────────────────────

const PHI = 1.618033988749895;
const VERSION = '1.0.0';

const COMMANDS = {
  call: 'Call a Julia function',
  list: 'List available functions',
  types: 'Show type mappings',
  validate: 'Validate a type',
  info: 'Show function information',
  help: 'Show this help message',
  version: 'Show version',
};

// ─── Argument Parser ──────────────────────────────────────────────────────────

function parseArgs(args) {
  const parsed = {
    command: null,
    function: null,
    options: {},
    positional: [],
  };
  
  let i = 0;
  while (i < args.length) {
    const arg = args[i];
    
    if (arg.startsWith('--')) {
      const key = arg.slice(2);
      const next = args[i + 1];
      
      if (next && !next.startsWith('--')) {
        parsed.options[key] = next;
        i += 2;
      } else {
        parsed.options[key] = true;
        i += 1;
      }
    } else if (!parsed.command) {
      parsed.command = arg;
      i += 1;
    } else {
      parsed.positional.push(arg);
      i += 1;
    }
  }
  
  if (parsed.positional.length > 0) {
    parsed.function = parsed.positional[0];
  }
  
  return parsed;
}

// ─── Value Parser ─────────────────────────────────────────────────────────────

function parseValue(value) {
  // If it's a file path, read from file
  if (value && typeof value === 'string') {
    if (existsSync(value) && (value.endsWith('.json') || value.endsWith('.txt'))) {
      const content = readFileSync(value, 'utf-8');
      return JSON.parse(content);
    }
    
    // Try parsing as JSON
    try {
      return JSON.parse(value);
    } catch {
      return value;
    }
  }
  return value;
}

// ─── Commands ─────────────────────────────────────────────────────────────────

async function cmdCall(funcName, options) {
  const { getJuliaCompute, JULIA_FUNCTIONS } = await import(protocolPath);
  
  if (!funcName) {
    console.error('Error: Function name required');
    console.error('Usage: nova-julia call <function> [--matrix <data>] [--data <data>]');
    process.exit(1);
  }
  
  // Validate function exists
  if (!JULIA_FUNCTIONS[funcName]) {
    console.error(`Error: Unknown function '${funcName}'`);
    console.error('Run "nova-julia list" to see available functions');
    process.exit(1);
  }
  
  // Initialize bridge
  const julia = getJuliaCompute({
    enableProofRecording: options['record-proof'] || false,
  });
  
  await julia.initialize();
  
  // Parse inputs
  const args = [];
  
  if (options.matrix) {
    args.push(parseValue(options.matrix));
  }
  if (options.data) {
    args.push(parseValue(options.data));
  }
  if (options.signal) {
    args.push(parseValue(options.signal));
  }
  if (options.x0) {
    args.push(parseValue(options.x0));
  }
  if (options.coefficients) {
    args.push(parseValue(options.coefficients));
  }
  
  // Map function name to method
  const methodMap = {
    'linalg.eigen': 'eigen',
    'linalg.svd': 'svd',
    'linalg.qr': 'qr',
    'linalg.lu': 'lu',
    'linalg.cholesky': 'cholesky',
    'signal.fft': 'fft',
    'signal.ifft': 'ifft',
    'stats.mean': 'mean',
    'stats.std': 'std',
    'stats.cov': 'cov',
    'stats.cor': 'cor',
    'optim.minimize': 'minimize',
    'phi.gradient_descent': 'phiGradientDescent',
    'phi.resonance_filter': 'phiResonanceFilter',
  };
  
  const method = methodMap[funcName];
  if (!method || typeof julia[method] !== 'function') {
    console.error(`Error: No method mapping for '${funcName}'`);
    process.exit(1);
  }
  
  try {
    const startTime = performance.now();
    const result = await julia[method](...args);
    const elapsed = performance.now() - startTime;
    
    // Output format
    const format = options.format || 'json';
    
    if (format === 'pretty') {
      console.log('Result:');
      console.log(JSON.stringify(result, null, 2));
      console.log(`\nCompute time: ${elapsed.toFixed(2)}ms`);
    } else {
      console.log(JSON.stringify(result));
    }
    
    // Show proof if recording
    if (options['record-proof']) {
      const proofs = julia.getAllProofRecords();
      if (proofs.length > 0) {
        console.error('\nProof Record:');
        console.error(JSON.stringify(proofs[proofs.length - 1], null, 2));
      }
    }
    
    // Output to file if specified
    if (options.output) {
      writeFileSync(options.output, JSON.stringify(result, null, 2));
      console.error(`Result written to ${options.output}`);
    }
    
  } catch (error) {
    console.error(`Error: ${error.message}`);
    process.exit(1);
  }
}

async function cmdList() {
  const { JULIA_FUNCTIONS } = await import(protocolPath);
  
  console.log('Available Julia Functions:\n');
  
  const categories = {};
  for (const [name, spec] of Object.entries(JULIA_FUNCTIONS)) {
    const category = name.split('.')[0];
    if (!categories[category]) {
      categories[category] = [];
    }
    categories[category].push({ name, ...spec });
  }
  
  for (const [category, funcs] of Object.entries(categories)) {
    console.log(`${category.toUpperCase()}`);
    console.log('─'.repeat(40));
    
    for (const func of funcs) {
      const phiMarker = func.phiEnhanced ? ' (φ-enhanced)' : '';
      console.log(`  ${func.name}${phiMarker}`);
      console.log(`    ${func.description}`);
      console.log(`    Input:  ${func.input.join(', ')}`);
      console.log(`    Output: ${func.output}`);
      console.log(`    Time:   ${func.complexity}`);
      console.log();
    }
  }
}

