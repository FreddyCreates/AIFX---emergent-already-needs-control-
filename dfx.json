{
  "version": 1,
  "dfx": "0.22.0",
  "canisters": {
    "organism_backend": {
      "type": "motoko",
      "main": "organism/motoko/src/Organism.mo"
    },
    "organism_frontend": {
      "type": "assets",
      "source": ["icp-dist"],
      "dependencies": ["organism_backend"]
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    },
    "ic": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    }
  },
  "output_env_file": ".env"
}
